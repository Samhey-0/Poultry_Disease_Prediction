# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-use-get-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# PostgreSQL connection string format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/poultry_db

# Model Directory
# Absolute path to the directory containing your trained ML model
MODEL_DIR=u:/Abdul_Haseeb(BAI)/FYP/saim/poultry-disease-prediction-full-stack-/model

# Google Maps API (optional, for vet clinic locator feature)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-from-cloud-console

# JWT Authentication (optional, defaults provided in settings.py)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

